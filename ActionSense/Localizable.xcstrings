    "about.text": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS smart clipboard assistant.\nPlain text purification + PasteFlow intent detection + intent history.\n\nPrivacy: All processing is local. Your data never leaves this machine.\n\nFeedback: https://github.com/xiaoyunchengzhu/ActionSense/issues\nAuthor: xiaoniubuniu.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 智能剪贴板助手。\n纯文本净化 + PasteFlow 智能识别 + 意图历史回溯。\n\n隐私声明：\n所有处理均在本地完成，数据永不上传。\n\n反馈：https://github.com/xiaoyunchengzhu/ActionSense/issues\n作者：xiaoniubuniu.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS スマートクリップボードアシスタント。\nプレーンテキスト浄化 + PasteFlow 意図検出 + 履歴。\n\nプライバシー：すべての処理はローカルで行われます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant presse-papiers macOS.\nTexte brut + détection d'intention PasteFlow + historique.\n\nConfidentialité : tout est traité localement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS Smart Clipboard Assistant.\nTextbereinigung + PasteFlow Erkennung + Verlauf.\n\nPrivatsphäre: Alle Verarbeitung erfolgt lokal."
          }
        }
      }
    },
